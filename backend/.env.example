APP_ENV=development
LOG_LEVEL=INFO

# LiteLLM Proxy（OpenAI 兼容）——三条 LLM 路径（PDF解析/建树/对话）统一入口
LITELLM_BASE_URL=https://litellm.internal.futurx.cc
LITELLM_API_KEY=sk-replace-me
LITELLM_DEFAULT_VLM_MODEL=qwen-vl-max

# 知识库引擎（pageindex-agent）
# 建树模型：litellm 路由名，需带 openai/ 前缀走 Proxy（OpenAI 兼容端点）
INDEX_MODEL=openai/gpt-4o
# 对话模型：Proxy 上的模型名
CHAT_MODEL=openai/gpt-4o
# 文件存储根（树/索引/目录），默认 backend/data；放 md 到 DATA_DIR/md 后调 /ingest/build-tree
DATA_DIR=data

# 多格式上传 → PDF 转换服务（Gotenberg，封装 LibreOffice）
# 容器内（docker-compose）用服务名 http://gotenberg:3000；本地裸跑 dev 用 localhost
GOTENBERG_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./torch_kb.db
